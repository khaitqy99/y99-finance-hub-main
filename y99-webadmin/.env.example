# Supabase (bắt buộc cho CMS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Chỉ dùng trên server admin (API routes) — KHÔNG public
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Tùy chọn — chạy migration bằng CLI (Session pooler URI từ Dashboard → Database)
# Cách 1 — chỉ cần mật khẩu DB (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=your_database_password

# Cách 2 — full URI (Session pooler)
# DATABASE_URL=postgresql://postgres.ccrvxhpujqsgkbyuiezt:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
